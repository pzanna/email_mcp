[Unit]
Description=Email MCP Server
After=network.target

[Service]
User=your-username
WorkingDirectory=/home/your-username/email-mcp
EnvironmentFile=/home/your-username/email-mcp/.env
ExecStart=/home/your-username/email-mcp/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8420
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
