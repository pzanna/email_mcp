# Email MCP Server Configuration
# Copy this file to .env and fill in your credentials

# ============================================================================
# IMAP Configuration (required)
# ============================================================================
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=you@example.com
IMAP_PASSWORD=your-imap-password
IMAP_SSL=true

# ============================================================================
# SMTP Configuration (required)
# ============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_STARTTLS=true

# ============================================================================
# MCP Server Configuration (required)
# ============================================================================

# API key for authentication (used by MCP clients)
MCP_API_KEY=your-secret-api-key-here

# Host to bind to:
# - Use 127.0.0.1 for local-only access (Mac development)
# - Use 0.0.0.0 to allow remote access (Ubuntu server deployment)
MCP_HOST=127.0.0.1

# Port to listen on
MCP_PORT=8420

# Server name
MCP_SERVER_NAME=email-mcp

# Base URL for this server:
# - Local (Mac): http://localhost:8420
# - Remote (Ubuntu): http://192.168.0.1:8420 (replace with your server IP)
MCP_BASE_URL=http://localhost:8420

# ============================================================================
# Behavior Configuration (optional)
# ============================================================================

# Default name to use in "From" field when sending emails
# Can be overridden per-email with the from_name parameter
DEFAULT_FROM_NAME=Your Name

# Maximum number of search results to return (max 50)
MAX_SEARCH_RESULTS=50

# Maximum number of concurrent IMAP connections
IMAP_POOL_SIZE=3

# ============================================================================
# Deployment Notes
# ============================================================================

# Mac (Local Development):
# - MCP_HOST=127.0.0.1
# - MCP_BASE_URL=http://localhost:8420
# - Run: uvicorn main:app --host 127.0.0.1 --port 8420

# Ubuntu (Remote Server):
# - MCP_HOST=0.0.0.0
# - MCP_BASE_URL=http://192.168.0.1:8420  (use your server's IP)
# - Install as systemd service:
#     sudo cp email-mcp.service /etc/systemd/system/
#     sudo systemctl daemon-reload
#     sudo systemctl enable email-mcp
#     sudo systemctl start email-mcp

# ============================================================================
# MCP Client Configuration
# ============================================================================

# Configure the MCP client to point to:
# - Local: http://localhost:8420/mcp
# - Remote: http://192.168.0.1:8420/mcp
#
# Include the X-API-Key header with the value from MCP_API_KEY
